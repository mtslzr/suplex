# Database
POSTGRES_DB=suplex
POSTGRES_PASSWORD=suplex
POSTGRES_USER=suplex

# API
API_PORT=8083

# Scraper
# User-Agent sent with cagematch.net requests. Describe what/who is scraping.
SCRAPER_USER_AGENT=suplex/0.1 (+https://github.com/mtslzr/suplex)
# Minimum milliseconds between requests to cagematch.net.
SCRAPER_RATE_LIMIT_MS=1000
